# Copy to .dev.vars (gitignored) for `wrangler dev`.

# --- V3 / Phase 4: Stripe (test mode) ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
PRICE_SELF_SERVE=price_xxx_49     # $49 self-serve (default Checkout tier)
PRICE_DONE_FOR_YOU=price_xxx_99   # $99 done-for-you (/convert?plan=done_for_you + portal upgrade)
# Checkout enables Stripe Tax (automatic_tax) — it collects only where a tax
# registration exists in the dashboard, so it's safe on from day one (§5a A).
# The customer portal (/portal/{handle}) needs its config saved once in the
# Stripe dashboard (Billing → Customer portal) for the $49→$99 upgrade + cancel.

# --- V1: Cloudflare provisioning (when set, real provisioning replaces the stub) ---
CF_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CF_API_TOKEN=xxx              # Workers + DNS + Zone + Registrar write (all-zones)
CF_WORKER_SERVICE=maps-website-builder
# CF_ENVIRONMENT=production    # optional

# --- V5: Resend (outbound lead email) ---
RESEND_API_KEY=re_xxx
# Quote values with spaces / `<>` so the file is also shell-sourceable (wrangler strips the quotes).
LEADS_FROM="OK Try Me <leads@oktryme.com>"
# Ops inbox: leads with no business email, plus Phase-4 ops alerts —
# provisioning-fallback warnings (§5a E) and done-for-you change requests (§6).
OPS_FALLBACK_EMAIL=ops@oktryme.com

# --- Phase 6 Track A: Sales CRM admin auth ---
# Shared secret for the /admin/* call-queue routes (HTML view, JSON, manual
# pipeline override, mail-status). Unset → /admin/* returns 503 (disabled), so
# the lead list never leaks. Reach it via `Authorization: Bearer <token>` or
# `?token=`. Only on the workers.dev URL — the oktryme.com proxy (§5b) doesn't
# forward /admin. Set in prod with: wrangler secret put ADMIN_TOKEN
ADMIN_TOKEN=choose-a-long-random-string

# --- Phase 5: postcard outreach (§1C) ---
# Worker secret: guards POST /postgrid/webhook (set `x-webhook-secret` on the
# PostGrid webhook to this value). Set in prod via `wrangler secret put`.
POSTGRID_WEBHOOK_SECRET=some_random_string
# Used by `npm run postcards` (the batch-send script), NOT the Worker:
POSTGRID_API_KEY=test_sk_xxx      # PostGrid test-mode key (sandbox = $0); live key only for real mail
# Return/sender address printed on every card — §5a requires NON-RESIDENTIAL
# (LLC registered-agent / virtual mailbox / PO box). Placeholders block --live.
POSTGRID_FROM_COMPANY="Multiply Technologies LLC"
POSTGRID_FROM_LINE1=REPLACE_ME
POSTGRID_FROM_LINE2=
POSTGRID_FROM_CITY=REPLACE_ME
POSTGRID_FROM_STATE=REPLACE_ME
POSTGRID_FROM_ZIP=REPLACE_ME

# --- Phase 3: ingest pipeline (used by `npm run ingest`, not the Worker) ---
OUTSCRAPER_API_KEY=xxx        # Google Maps scrape (per-record cost) — businesses pull
GEMINI_API_KEY=xxx            # Gemini — drives BOTH AI copy (§7 #5 guardrails) and
                              # Nano Banana Pro per-trade hero image generation

PREVIEW_HOST=oktryme.com
